          <div class="stack-item"><i class="devicon-nodejs-plain colored"></i><span>Node.js</span></div>
          <div class="stack-item"><i class="devicon-javascript-plain colored"></i><span>JavaScript</span></div>
          <div class="stack-item"><i class="devicon-typescript-plain colored"></i><span>TypeScript</span></div>
          <div class="stack-item"><i class="devicon-java-plain colored"></i><span>Java</span></div>
          <div class="stack-item"><i class="devicon-php-plain colored"></i><span>PHP</span></div>
