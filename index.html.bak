      <span>Agile</span><span class="dot">&#183;</span>
      <span>Full-Stack Engineering</span><span class="dot">&#183;</span>
      <span>Backend Development</span><span class="dot">&#183;</span>
      <span>REST APIs</span><span class="dot">&#183;</span>
      <span>Node.js</span><span class="dot">&#183;</span>
      <span>PostgreSQL</span><span class="dot">&#183;</span>
      <span>MongoDB</span><span class="dot">&#183;</span>
      <span>Java</span><span class="dot">&#183;</span>
      <span>PHP</span><span class="dot">&#183;</span>
      <span>Cloud Architecture</span><span class="dot">&#183;</span>
      <span>Agile</span><span class="dot">&#183;</span>
      <span>Full-Stack Engineering</span><span class="dot">&#183;</span>
