  <!-- HERO -->
  <section class="hero" id="hero">
    <div class="hero-text reveal-up">
      <div class="hero-eyebrow">
        <span class="eyebrow-dot"></span>
        Available for opportunities
      </div>
      <h1 class="hero-name">
        <em class="serif-italic">Dhyey</em> Desai
      </h1>
      <div class="hero-roles">
        <span class="role-prefix">I am a&nbsp;</span>
        <span class="role-sliding" id="roleSliding" aria-live="polite"></span>
      </div>
      <p class="hero-desc">
        I build scalable APIs, backend systems, and full-stack
        applications that are clean, performant, and production-ready.
      </p>
      <div class="hero-cta">
        <a href="#projects" class="btn-primary">View Projects</a>
        <a href="#contact" class="btn-ghost">Get in touch</a>
      </div>
      <div class="hero-stats">
        <div class="stat"><span class="stat-num">2+</span><span class="stat-label">Years Experience</span></div>
        <div class="stat-divider"></div>
        <div class="stat"><span class="stat-num">4+</span><span class="stat-label">Projects Built</span></div>
        <div class="stat-divider"></div>
        <div class="stat"><span class="stat-num">2</span><span class="stat-label">Cloud Certs</span></div>
      </div>
    </div>

    <!-- Lanyard -->
    <div class="lanyard-wrapper" id="lanyardWrapper" aria-hidden="true">
      <canvas class="lanyard-canvas" id="lanyardCanvas"></canvas>
      <div class="lanyard-card" id="lanyardCard">
        <div class="lcard-stripe"></div>
        <div class="lcard-clip"></div>
        <div class="lcard-inner">
          <div class="lcard-photo">
            <img src="media/DhyeyGraduation.jpeg" alt="Dhyey Desai" draggable="false" />
          </div>
          <div class="lcard-info">
            <div class="lcard-name">Dhyey Desai</div>
            <div class="lcard-title" id="lanyardRole">Backend Developer</div>
            <div class="lcard-id">ID · 2024-DEV-001</div>
          </div>
          <div class="lcard-badge">
            <span class="lcard-badge-dot"></span>
            <span>OPEN TO WORK</span>
          </div>
          <div class="lcard-barcode" aria-hidden="true">
            <div class="barcode-lines"></div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- TICKER -->
  <div class="ticker-wrap" aria-hidden="true">
    <div class="ticker-fade ticker-fade--left"></div>
    <div class="ticker-fade ticker-fade--right"></div>
    <div class="ticker-track">
      <span>Backend Development</span><span class="dot">&#183;</span>
      <span>REST APIs</span><span class="dot">&#183;</span>
      <span>Node.js</span><span class="dot">&#183;</span>
      <span>PostgreSQL</span><span class="dot">&#183;</span>
