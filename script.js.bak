'use strict';

// ── Theme System ─────────────────────────────────────────────
const HTML    = document.documentElement;
const TOGGLE  = document.getElementById('themeToggle');

function applyTheme(t) {
  HTML.setAttribute('data-theme', t);
  localStorage.setItem('dd-theme', t);
}
applyTheme(localStorage.getItem('dd-theme') || 'dark');
if (TOGGLE) TOGGLE.addEventListener('click', () => {
  applyTheme(HTML.getAttribute('data-theme') === 'dark' ? 'light' : 'dark');
});

// ── Nav scroll state ─────────────────────────────────────────
const NAV = document.getElementById('mainNav');
window.addEventListener('scroll', () => {
  NAV && NAV.classList.toggle('scrolled', window.scrollY > 20);
}, { passive: true });

// ── Scroll Reveal ─────────────────────────────────────────────
const revealIO = new IntersectionObserver(
  (entries) => entries.forEach(e => {
    if (e.isIntersecting) { e.target.classList.add('visible'); revealIO.unobserve(e.target); }
  }),
  { threshold: 0.1 }
);
document.querySelectorAll('.reveal-up').forEach(el => revealIO.observe(el));

// ── Nav active link ───────────────────────────────────────────
const NAV_LINKS = document.querySelectorAll('.nav-link');
const SEC_IO = new IntersectionObserver(entries => {
  entries.forEach(e => {
    if (e.isIntersecting) {
      NAV_LINKS.forEach(a => a.classList.remove('active'));
      const a = document.querySelector('.nav-link[href="#' + e.target.id + '"]');
      if (a) a.classList.add('active');
    }
  });
}, { rootMargin: '-45% 0px -50% 0px' });
document.querySelectorAll('section[id]').forEach(s => SEC_IO.observe(s));

// ── Role Slider (hero + lanyard card) ─────────────────────────
const ROLES = [
  'Software Developer',
  'Backend Developer',
  'Full-Stack Engineer',
  'Cloud Administrator',
  'Web & Mobile Developer',
];

const roleSliding  = document.getElementById('roleSliding');
const lanyardRole  = document.getElementById('lanyardRole');
let roleIdx = 0;

function nextRole() {
  const next = ROLES[roleIdx];

  // hero slide out
  if (roleSliding) {
    roleSliding.classList.add('exiting');
    setTimeout(() => {
      roleSliding.textContent = next;
      roleSliding.classList.remove('exiting');
      roleSliding.classList.add('entering');
      // force reflow
      void roleSliding.offsetWidth;
      roleSliding.classList.remove('entering');
    }, 350);
  }

  // lanyard card fade
  if (lanyardRole) {
    lanyardRole.style.opacity = '0';
    setTimeout(() => {
      lanyardRole.textContent = next;
      lanyardRole.style.opacity = '1';
    }, 350);
  }

  roleIdx = (roleIdx + 1) % ROLES.length;
}

if (roleSliding) { roleSliding.textContent = ROLES[0]; }
if (lanyardRole) { lanyardRole.style.transition = 'opacity 0.35s ease'; }
setInterval(nextRole, 2000);

// ── Lanyard Physics ───────────────────────────────────────────
(function initLanyard() {
  const wrapper = document.getElementById('lanyardWrapper');
  const canvas  = document.getElementById('lanyardCanvas');
  const card    = document.getElementById('lanyardCard');
  if (!wrapper || !canvas || !card) return;

  // Mobile: handled by CSS (static card, no physics)
  if (window.innerWidth < 768) { return; }

  const ctx = canvas.getContext('2d');
  const NUM  = 24;     // rope segments
  const GRAV = 0.52;
  const DAMP = 0.975;
  const ITER = 10;

  let W = 0, H = 0;
  let pts = [];
  let segLen = 0;
  let dragging = false;
  let dragOff = { x: 0, y: 0 };
  let raf;

  function resize() {
    const r = wrapper.getBoundingClientRect();
    W = canvas.width  = r.width;
    H = canvas.height = r.height;
  }

  function initPts() {
    pts = [];
    segLen = (H * 0.68) / NUM;
    for (let i = 0; i <= NUM; i++) {
      // All points start at pin (top) — gravity pulls them down naturally
      pts.push({
        x: W / 2,
        y: 0,
        px: W / 2 + (Math.random() - 0.5) * 0.02,
        py: 0,
        pinned: i === 0
      });
    }
  }

  function step() {
    for (const p of pts) {
      if (p.pinned) continue;
      const vx = (p.x - p.px) * DAMP;
      const vy = (p.y - p.py) * DAMP;
      p.px = p.x; p.py = p.y;
      p.x += vx;
      p.y += vy + GRAV;
    }
    for (let it = 0; it < ITER; it++) {
      for (let i = 0; i < pts.length - 1; i++) {
        const a = pts[i], b = pts[i + 1];
        const dx = b.x - a.x, dy = b.y - a.y;
        const d = Math.sqrt(dx * dx + dy * dy) || 0.0001;
        const f = (d - segLen) / d * 0.5;
        const ox = dx * f, oy = dy * f;
        if (!a.pinned) { a.x += ox; a.y += oy; }
        if (!b.pinned) { b.x -= ox; b.y -= oy; }
      }
    }
  }

  function draw() {
    ctx.clearRect(0, 0, W, H);
    const pin = pts[0];
    const tip = pts[pts.length - 1];

    // rope shadow
    ctx.save();
    ctx.shadowColor = 'rgba(0,0,0,0.5)';
    ctx.shadowBlur = 8;
    ctx.shadowOffsetY = 3;

    const g = ctx.createLinearGradient(pin.x, pin.y, tip.x, tip.y);
    g.addColorStop(0, 'rgba(200,200,200,0.9)');
    g.addColorStop(1, 'rgba(100,100,100,0.5)');

    ctx.beginPath();
    ctx.moveTo(pin.x, pin.y);
    for (let i = 1; i < pts.length; i++) {
      const prev = pts[i - 1];
      const mx = (prev.x + pts[i].x) / 2;
      const my = (prev.y + pts[i].y) / 2;
      ctx.quadraticCurveTo(prev.x, prev.y, mx, my);
    }
    ctx.lineTo(tip.x, tip.y);
    ctx.strokeStyle = g;
    ctx.lineWidth = 3;
    ctx.lineCap = 'round';
    ctx.stroke();
    ctx.restore();

    // pin dot
    ctx.beginPath();
    ctx.arc(pin.x, pin.y, 5, 0, Math.PI * 2);
    ctx.fillStyle = '#777';
    ctx.fill();

    // position card
    const cW = card.offsetWidth;
    card.style.left = (tip.x - cW / 2) + 'px';
    card.style.top  = tip.y + 'px';

    // natural tilt from velocity
    const vel = (tip.x - pts[pts.length - 2].x) * 4;
    const tilt = Math.max(-20, Math.min(20, vel));
    card.style.transform = 'rotate(' + tilt + 'deg)';
  }

  function loop() {
    step();
    draw();
    raf = requestAnimationFrame(loop);
  }

  // ── Input helpers
  function pointerPos(e) {
    const r = canvas.getBoundingClientRect();
    const sx = W / r.width, sy = H / r.height;
    const src = e.touches ? e.touches[0] : e;
    return { x: (src.clientX - r.left) * sx, y: (src.clientY - r.top) * sy };
  }

  function onDown(e) {
    e.preventDefault();
    dragging = true;
    const pos = pointerPos(e);
    const tip = pts[pts.length - 1];
    dragOff = { x: pos.x - tip.x, y: pos.y - tip.y };
  }

  function onMove(e) {
    if (!dragging) return;
    e.preventDefault();
    const pos = pointerPos(e);
    const tip = pts[pts.length - 1];
    tip.x = pos.x - dragOff.x; tip.px = tip.x;
    tip.y = pos.y - dragOff.y; tip.py = tip.y;
  }

  function onUp() { dragging = false; }

  card.addEventListener('mousedown',  onDown, { passive: false });
  card.addEventListener('touchstart', onDown, { passive: false });
  window.addEventListener('mousemove', onMove);
  window.addEventListener('touchmove', onMove, { passive: false });
  window.addEventListener('mouseup', onUp);
  window.addEventListener('touchend', onUp);

  // ── Parallax on scroll
  window.addEventListener('scroll', () => {
    const scrollY = window.scrollY;
    const maxScroll = window.innerHeight;
    const progress = Math.min(scrollY / maxScroll, 1);
    const offset = -60 - progress * 120;
    const opacity = 1 - progress * 1.4;
    wrapper.style.transform = 'translateY(' + offset + 'px)';
    wrapper.style.opacity = Math.max(0, opacity).toString();
  }, { passive: true });

  window.addEventListener('resize', () => {
    if (window.innerWidth < 768) {
      cancelAnimationFrame(raf);
      return;
    }
    resize();
    initPts();
  });

  resize();
  initPts();
  loop();
})();

// ── Bento card stagger
document.querySelectorAll('.bento-card').forEach((c, i) => {
  c.style.setProperty('--delay', i * 70 + 'ms');
});
