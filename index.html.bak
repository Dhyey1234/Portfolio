  <!-- WORK EXPERIENCE -->
  <section class="section" id="work">
    <div class="section-header reveal-up">
      <div class="section-label">01 / Work</div>
      <h2 class="section-title">Experience</h2>
      <p class="section-sub">Where I have worked and what I have done.</p>
    </div>
    <div class="timeline">

      <article class="timeline-item reveal-up">
        <div class="timeline-meta">
          <span class="timeline-period">Jan 2024 – Mar 2024</span>
          <span class="timeline-loc">Surat, India</span>
          <span class="timeline-status timeline-status--done">Completed</span>
        </div>
        <div class="timeline-body">
          <h3 class="timeline-role">Backend Developer</h3>
          <div class="timeline-company">Sarvadhi Solutions</div>
          <ul class="timeline-bullets">
            <li>Developed web applications and RESTful APIs with third-party integrations</li>
            <li>Worked with PostgreSQL and MongoDB, optimizing queries and performance</li>
            <li>Performed debugging, testing, and troubleshooting in an Agile environment</li>
            <li>Contributed to API design, documentation, and backend workflows</li>
          </ul>
          <div class="timeline-tags">
            <span>JavaScript</span><span>Node.js</span><span>Java</span>
            <span>PHP</span><span>PostgreSQL</span><span>MongoDB</span>
            <span>REST APIs</span><span>Git</span>
          </div>
        </div>
      </article>

      <article class="timeline-item reveal-up" style="--delay:100ms">
        <div class="timeline-meta">
          <span class="timeline-period">Feb 2025 – Present</span>
          <span class="timeline-loc">Kitchener, ON</span>
          <span class="timeline-status timeline-status--active">Current</span>
        </div>
        <div class="timeline-body">
          <h3 class="timeline-role">Service Supervisor</h3>
          <div class="timeline-company">Farm Boy</div>
          <ul class="timeline-bullets">
            <li>Led daily operations and managed workflow coordination</li>
            <li>Resolved issues to ensure a smooth customer experience</li>
            <li>Applied strong problem-solving and communication skills in fast-paced settings</li>
          </ul>
          <div class="timeline-tags">
            <span>Leadership</span><span>Operations</span><span>Problem-Solving</span>
          </div>
        </div>
      </article>

    </div>
  </section>

  <!-- TECH STACK -->
  <section class="section" id="stack">
    <div class="section-header reveal-up">
      <div class="section-label">02 / Stack</div>
      <h2 class="section-title">Technologies</h2>
      <p class="section-sub">Tools I work with daily.</p>
    </div>
    <div class="stack-loop-wrap">
      <div class="stack-loop-fade stack-loop-fade--left"></div>
      <div class="stack-loop-fade stack-loop-fade--right"></div>
      <div class="stack-loop">
        <div class="stack-set">
          <div class="stack-item"><i class="devicon-nodejs-plain colored"></i><span>Node.js</span></div>
          <div class="stack-item"><i class="devicon-javascript-plain colored"></i><span>JavaScript</span></div>
          <div class="stack-item"><i class="devicon-typescript-plain colored"></i><span>TypeScript</span></div>
