  <!-- PROJECTS BENTO -->
  <section class="section" id="projects">
    <div class="section-header reveal-up">
      <div class="section-label">03 / Projects</div>
      <h2 class="section-title">Selected Work</h2>
      <p class="section-sub">Things I have built that I am proud of.</p>
    </div>
    <div class="bento">

      <!-- Featured: 2x2 -->
      <article class="bento-card bento-card--featured reveal-up">
        <div class="bento-card-header">
          <div class="bento-card-badges">
            <span class="bento-tag">Full Stack</span>
            <span class="bento-status bento-status--done">Completed</span>
          </div>
          <h3 class="bento-card-title">Bookstore App</h3>
          <p class="bento-card-desc">A full-stack bookstore platform with user authentication, inventory management, order tracking, and an admin dashboard. Built with a RESTful API backend and a React frontend.</p>
        </div>
        <div class="bento-card-img-wrap">
          <img src="media/Bookstore.png" alt="Bookstore App" loading="lazy" />
        </div>
        <div class="bento-card-footer">
          <div class="bento-card-techs">
            <span>Node.js</span><span>PostgreSQL</span><span>React</span><span>REST API</span>
          </div>
          <div class="bento-card-actions">
            <a href="#" class="bento-btn bento-btn--ghost" aria-label="GitHub repo">
              <svg width="14" height="14" viewBox="0 0 24 24" fill="currentColor"><path d="M12 0C5.37 0 0 5.37 0 12c0 5.3 3.44 9.8 8.2 11.38.6.11.82-.26.82-.58v-2.02c-3.34.72-4.04-1.61-4.04-1.61-.55-1.39-1.34-1.76-1.34-1.76-1.09-.74.08-.73.08-.73 1.2.08 1.84 1.24 1.84 1.24 1.07 1.83 2.8 1.3 3.49 1 .11-.78.42-1.3.76-1.6-2.67-.3-5.47-1.33-5.47-5.93 0-1.31.47-2.38 1.24-3.22-.12-.3-.54-1.52.12-3.17 0 0 1.01-.32 3.3 1.23a11.5 11.5 0 0 1 3-.4c1.02.005 2.04.138 3 .4 2.28-1.55 3.29-1.23 3.29-1.23.66 1.65.24 2.87.12 3.17.77.84 1.23 1.91 1.23 3.22 0 4.61-2.81 5.63-5.48 5.92.43.37.81 1.1.81 2.22v3.29c0 .32.22.7.83.58C20.57 21.8 24 17.3 24 12c0-6.63-5.37-12-12-12z"/></svg>
              GitHub
            </a>
            <a href="#" class="bento-btn bento-btn--primary">Live Demo &#8599;</a>
          </div>
        </div>
      </article>

      <!-- Tall card -->
      <article class="bento-card bento-card--tall reveal-up" style="--delay:80ms">
        <div class="bento-card-header">
          <div class="bento-card-badges">
            <span class="bento-tag">Frontend</span>
            <span class="bento-status bento-status--done">Completed</span>
          </div>
          <h3 class="bento-card-title">Weather App</h3>
          <p class="bento-card-desc">Live weather dashboard consuming OpenWeather API with location search and animated conditions.</p>
        </div>
        <div class="bento-card-img-wrap">
          <img src="media/weatherApp.png" alt="Weather App" loading="lazy" />
        </div>
        <div class="bento-card-footer">
          <div class="bento-card-techs"><span>JavaScript</span><span>REST API</span></div>
          <div class="bento-card-actions">
            <a href="#" class="bento-btn bento-btn--ghost">GitHub</a>
            <a href="#" class="bento-btn bento-btn--primary">Demo &#8599;</a>
          </div>
        </div>
      </article>

      <!-- Medium card -->
      <article class="bento-card reveal-up" style="--delay:120ms">
        <div class="bento-card-header">
          <div class="bento-card-badges">
            <span class="bento-tag">Backend</span>
            <span class="bento-status bento-status--done">Completed</span>
          </div>
          <h3 class="bento-card-title">Employee Management System</h3>
          <p class="bento-card-desc">REST API for employee records, departments, and payroll with role-based access control.</p>
        </div>
        <div class="bento-card-img-wrap">
          <img src="media/Employeemangementsystem.png" alt="Employee Management System" loading="lazy" />
        </div>
        <div class="bento-card-footer">
          <div class="bento-card-techs"><span>Java</span><span>PostgreSQL</span></div>
          <div class="bento-card-actions">
            <a href="#" class="bento-btn bento-btn--ghost">GitHub</a>
          </div>
        </div>
      </article>

      <!-- Medium card -->
      <article class="bento-card reveal-up" style="--delay:160ms">
        <div class="bento-card-header">
          <div class="bento-card-badges">
            <span class="bento-tag">Web</span>
            <span class="bento-status bento-status--done">Completed</span>
          </div>
          <h3 class="bento-card-title">Body &amp; Care Works</h3>
          <p class="bento-card-desc">E-commerce front-end for a wellness brand with product catalog, cart, and checkout flow.</p>
        </div>
        <div class="bento-card-img-wrap">
          <img src="media/Bodyandcareworks.png" alt="Body and Care Works" loading="lazy" />
        </div>
        <div class="bento-card-footer">
          <div class="bento-card-techs"><span>PHP</span><span>MySQL</span></div>
          <div class="bento-card-actions">
            <a href="#" class="bento-btn bento-btn--ghost">GitHub</a>
          </div>
        </div>
      </article>

    </div>
  </section>

  <!-- CERTIFICATIONS -->
  <section class="section" id="certs">
    <div class="section-header reveal-up">
      <div class="section-label">04 / Certifications</div>
      <h2 class="section-title">Credentials</h2>
      <p class="section-sub">Industry certifications validating my cloud expertise.</p>
    </div>
    <div class="certs-bento">

      <article class="cert-card reveal-up">
        <div class="cert-card-logo">
          <img src="media/Claude Code.jpeg" alt="Claude Code cert" loading="lazy" />
        </div>
        <div class="cert-card-content">
          <div class="cert-card-org">Anthropic / AWS</div>
          <h3 class="cert-card-title">Claude Code in Action</h3>
          <p class="cert-card-desc">Hands-on certification covering AI-powered development with Claude, including API integration, prompt engineering, and building production AI applications.</p>
          <div class="cert-card-meta">
            <span class="cert-date">Issued 2025</span>
          </div>
          <div class="cert-card-skills">
            <span>AI Integration</span><span>Prompt Engineering</span>
            <span>Claude SDK</span><span>API Development</span>
          </div>
          <a href="#" class="cert-card-verify">Verify Certificate &#8599;</a>
        </div>
      </article>

      <article class="cert-card reveal-up" style="--delay:80ms">
        <div class="cert-card-logo">
          <img src="media/AZ104.jpeg" alt="AZ-104 cert" loading="lazy" />
        </div>
        <div class="cert-card-content">
          <div class="cert-card-org">Microsoft Azure</div>
          <h3 class="cert-card-title">AZ-104 Azure Administrator</h3>
          <p class="cert-card-desc">Validates expertise in managing Azure identities, governance, storage, compute resources, and virtual networking in enterprise environments.</p>
          <div class="cert-card-meta">
            <span class="cert-date">Issued 2024</span>
          </div>
          <div class="cert-card-skills">
            <span>Azure Admin</span><span>Virtual Networks</span>
            <span>Identity &amp; Access</span><span>Storage Management</span>
          </div>
          <a href="#" class="cert-card-verify">Verify Certificate &#8599;</a>
        </div>
      </article>

      <article class="cert-card reveal-up" style="--delay:160ms">
        <div class="cert-card-logo">
          <img src="media/Aws Cloud Practioner Essntials.jpeg" alt="AWS cert" loading="lazy" />
        </div>
        <div class="cert-card-content">
          <div class="cert-card-org">Amazon Web Services</div>
          <h3 class="cert-card-title">AWS Cloud Practitioner Essentials</h3>
          <p class="cert-card-desc">Foundational certification covering core AWS cloud concepts, global infrastructure, services, pricing models, and security best practices.</p>
          <div class="cert-card-meta">
            <span class="cert-date">Issued 2024</span>
          </div>
          <div class="cert-card-skills">
            <span>Cloud Computing</span><span>AWS Services</span>
            <span>Security &amp; Compliance</span><span>Billing &amp; Pricing</span>
          </div>
          <a href="#" class="cert-card-verify">Verify Certificate &#8599;</a>
        </div>
      </article>

    </div>
  </section>

  <!-- CONTACT -->
